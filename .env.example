# Telegram Bot Token (get from @BotFather on Telegram)
BOT_TOKEN=your_bot_token_here

# Target chat/channel ID (e.g., -1001234567890)
# For a group: use @getidsbot or forward a message from the group to @getidsbot
# For a channel: the ID is usually -100 followed by digits
CHAT_ID=-1001234567890

# Poll question (max 300 chars). Use {date} to insert the next Tuesday's date.
POLL_QUESTION=Training on {date}

# Comma-separated poll options (2-10 options, each max 100 chars)
POLL_OPTIONS=Coming, Not Coming

# IANA timezone (e.g., UTC, Asia/Shanghai, Asia/Singapore, America/New_York)
POLL_TIMEZONE=Asia/Singapore

# Whether the poll is anonymous (true/false)
POLL_IS_ANONYMOUS=false

# Allow multiple answers? (true/false)
POLL_ALLOWS_MULTIPLE=false

# Days until poll auto-closes (1-30, default: 7)
POLL_CLOSE_DAYS=7

# strftime format for the {date} placeholder (default: %Y-%m-%d)
# Common formats:
#   %Y-%m-%d       → 2026-07-10
#   %A, %B %d      → Friday, July 10
#   %d/%m/%Y       → 10/07/2026
POLL_DATE_FORMAT=%A, %B %d

# Optional: a message template to send before the poll.
# Use {date} to insert the same date as the poll question.
# Leave empty to skip sending a template message.
# Supports Telegram parse modes (HTML, MarkdownV2) via TEMPLATE_PARSE_MODE.
TEMPLATE_MESSAGE=
TEMPLATE_PARSE_MODE=
