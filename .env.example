# Telegram Bot Token (get from @BotFather on Telegram)
BOT_TOKEN=your_bot_token_here

# Target chat/channel ID (e.g., -1001234567890)
# For a group: use @getidsbot or forward a message from the group to @getidsbot
# For a channel: the ID is usually -100 followed by digits
CHAT_ID=-1001234567890

# Voting question (use {date} to insert the next Tuesday's date)
POLL_QUESTION=Training on {date}

# Date format for the {date} placeholder (strftime format)
# Examples: %A, %B %d → Tuesday, July 14  |  %Y-%m-%d → 2026-07-14
POLL_DATE_FORMAT=%A, %B %d

# Comma-separated voting options (each becomes an inline button)
POLL_OPTIONS=Coming, Not Coming

# IANA timezone (e.g., UTC, Asia/Shanghai, Asia/Singapore, America/New_York)
POLL_TIMEZONE=Asia/Singapore

# Optional message template sent before the voting message. Use {date} for the same date.
# Use \n for line breaks.
TEMPLATE_MESSAGE=
TEMPLATE_PARSE_MODE=
