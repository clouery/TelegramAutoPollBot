# Telegram Bot Token (get from @BotFather on Telegram)
BOT_TOKEN=your_bot_token_here

# Target chat/channel ID (e.g., -1001234567890)
# For a group: use @getidsbot or forward a message from the group to @getidsbot
# For a channel: the ID is usually -100 followed by digits
CHAT_ID=-1001234567890

# Poll question (max 300 chars). Use {date} to insert today's date.
# Examples:
#   POLL_QUESTION=What are you doing on {date}?
#   POLL_QUESTION=Daily Standup - {date}
POLL_QUESTION=What are you doing on {date}?

# Comma-separated poll options (2-10 options, each max 100 chars)
POLL_OPTIONS=Python, TypeScript, Rust, Go

# Day of week to send the poll (0=Sunday, 1=Monday, ..., 6=Saturday)
POLL_DAY=1

# Time to send in HH:MM 24h format
POLL_TIME=09:00

# IANA timezone (e.g., UTC, Asia/Shanghai, America/New_York, Europe/London)
POLL_TIMEZONE=UTC

# Whether the poll is anonymous (true/false)
POLL_IS_ANONYMOUS=true

# Allow multiple answers? (true/false, only for regular polls)
POLL_ALLOWS_MULTIPLE=false

# Seconds the poll stays open (5-600, default: 300)
POLL_OPEN_PERIOD=300

# strftime format for the {date} placeholder in POLL_QUESTION (default: %Y-%m-%d)
# Common formats:
#   %Y-%m-%d       → 2026-07-10
#   %A, %B %d      → Friday, July 10
#   %m/%d/%Y       → 07/10/2026
#   %d/%m/%Y       → 10/07/2026
POLL_DATE_FORMAT=%Y-%m-%d